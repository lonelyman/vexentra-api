# .env.example
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# App Config
API_ENV=development                  # development | production
API_PORT=3000
API_TIMEZONE=Asia/Bangkok
API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Postgres Primary DB Config
POSTGRES_PRIMARY_HOST=localhost
POSTGRES_PRIMARY_PORT=5432
POSTGRES_PRIMARY_USER=your_db_user
POSTGRES_PRIMARY_PASSWORD=your_db_password
POSTGRES_PRIMARY_NAME=your_db_name
POSTGRES_PRIMARY_SSL_MODE=disable

# External Port for local tools (DBeaver / TablePlus)
POSTGRES_EXTERNAL_PORT=5433

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_EXTERNAL_PORT=6380

# JWT Config
# Use long, random strings — e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRY=60m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRY=336h
JWT_ISSUER=your-app-name
